{
  "name": "smart-voice-notebook",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:open": "vite --host 127.0.0.1 --port 3000",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "smoke:voice": "node scripts/voice-smoke.mjs",
    "smoke:shopping": "node scripts/shopping-routing-smoke.mjs",
    "ios:add": "npx cap add ios",
    "ios:sync": "npm run build && npx cap sync ios",
    "ios:open": "npx cap open ios",
    "ios:prepare": "npm run ios:sync"
  },
  "dependencies": {
    "@capacitor/core": "^7.4.3",
    "@vercel/blob": "^2.3.3",
    "@vitejs/plugin-react": "6.0.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "vite": "8.0.10",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.3",
    "@capacitor/ios": "^7.4.3",
    "typescript": "^6.0.3"
  }
}

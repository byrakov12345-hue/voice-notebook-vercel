# Локальный AI-разбор работает бесплатно прямо в браузере.
#
# Для уведомлений при закрытой странице нужен серверный Web Push:
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com
# BLOB_READ_WRITE_TOKEN=
#
# Альтернатива Vercel Blob: Upstash/Redis REST.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
